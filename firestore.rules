rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: members
    // Fields:
    //   - name: string (required)
    //   - roomRentEnabled: bool (required)
    //   - messBillEnabled: bool (required)
    //   - totalDays: number (required)
    //   - uid: string (required, immutable)
    //
    // Collection: purchases
    // Fields:
    //   - description: string (required)
    //   - amount: number (required)
    //   - date: string (required)
    //   - memberId: string (required)
    //   - uid: string (required, immutable)
    //
    // Collection: summaries
    // Fields:
    //   - month: string (required)
    //   - totalRoomRent: number (required)
    //   - totalPurchase: number (required)
    //   - totalDays: number (required)
    //   - perDayRate: number (required)
    //   - memberDetails: string (required, JSON)
    //   - uid: string (required, immutable)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "sakeerputhan@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidMember(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.roomRentEnabled is bool &&
             data.messBillEnabled is bool &&
             data.totalDays is number && data.totalDays >= 0;
    }

    function isValidPurchase(data) {
      return data.description is string && data.description.size() > 0 && data.description.size() < 200 &&
             data.amount is number && data.amount >= 0 &&
             data.date is string &&
             data.memberId is string;
    }

    function isValidSummary(data) {
      return data.month is string &&
             data.totalRoomRent is number &&
             data.totalPurchase is number &&
             data.totalDays is number &&
             data.perDayRate is number &&
             data.memberDetails is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /members/{memberId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidMember(request.resource.data) && uidUnchanged();
      allow update: if isAdmin() && isValidMember(request.resource.data) && uidNotModified();
      allow delete: if isAdmin();
    }

    match /purchases/{purchaseId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidPurchase(request.resource.data) && uidUnchanged();
      allow update: if isAdmin() && isValidPurchase(request.resource.data) && uidNotModified();
      allow delete: if isAdmin();
    }

    match /summaries/{summaryId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidSummary(request.resource.data) && uidUnchanged();
      allow update: if isAdmin() && isValidSummary(request.resource.data) && uidNotModified();
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /registrations/{regId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
  }
}
